{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Miserarenaiyo",
  "version": "0.1.5",
  "identifier": "com.fujim.miserarenaiyo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Miserarenaiyo",
        "width": 240,
        "height": 240,
        "visible": false
      }
    ],
    "trayIcon": {
      "id": "miserarenaiyo",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": false,
      "showMenuOnLeftClick": true
    },
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
